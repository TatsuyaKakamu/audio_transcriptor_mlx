# mlx-audio-transcriptor 設定ファイル
#
# 配置先: ~/.config/mlx-audio-transcriptor/config.toml
# 参照: GUI (python -m app.main) と ヘッドレス CLI (python -m app.cli scan) の両方
#
# 全ての項目は省略可。未指定ならコード内のデフォルトが使われる。

# 文字起こしの既定言語 ("ja" / "en" など ISO 639-1)
language = "ja"

# 既定モデル名 ("tiny" / "base" / "small" / "medium" / "large-v3" もしくは任意)
# 未登録名は mlx-community/whisper-<name>-mlx として解決される
model = "medium"

# 監視するフォルダ（CLI scan モードの対象）
# ~ は自動展開される
watch_dir = "~/Downloads"

# 対象とする拡張子（小文字、ドット付き推奨）
extensions = [".wav", ".mp3"]

# ファイル書き込み完了を待つための安定判定秒数
# この秒数だけ size / mtime が変化しなければ転記対象と見なす
file_stability_seconds = 3.0

# true の場合、Markdown 出力成功後に元の音声ファイルを macOS のゴミ箱へ移動する
# false にすると元ファイルは残る（その場合、再スキャン時は *.transcript.md の
# 有無で既処理判定される）
trash_source_after_success = true

# 議事録生成（Ollama 連携）
#
# 有効化すると、トランスクリプト書き出し直後にローカルの Ollama を呼び出して
# 議事録 Markdown を生成し、`<元音声の日付(YYYY-MM-DD)>_<英語スラッグ>.md` という
# ファイル名でトランスクリプトと同じディレクトリに書き出す（本文は日本語、
# ファイル名は LLM が生成する英語スラッグで必ず半角英数字になる）。
# 失敗してもトランスクリプト本体には影響しない。
#
# 事前準備:
#   1) `brew install ollama` などで Ollama をインストール
#   2) `ollama serve` を起動
#   3) `ollama pull gemma4` などで使うモデルを取得
[minutes]
# false の場合、Ollama 連携を一切行わない (default: true)
enabled = true

# Ollama のエンドポイント (default: "http://localhost:11434")
ollama_host = "http://localhost:11434"

# 利用するモデル名。`ollama list` で確認できるものを指定
# Gemma 4 E4B は 128k トークンのコンテキストをサポート
# 参照: https://ai.google.dev/gemma/docs/core/model_card_4?hl=ja
model = "gemma4"

# プロンプト言語 ("ja" / "en")。出力の見出しがこの言語になる
prompt_language = "ja"

# Ollama に渡すコンテキスト長（トークン数）。
# 指定しない場合 Ollama のデフォルト (2048) で動作し、長尺入力が黙って切り詰められるため
# 必ず指定すること。`ollama show <model>` の context length を確認して設定。
# 目安: 8GB Mac → 16384、16GB Mac → 32768、32GB+ Mac → 65536
# (default: 32768)
num_ctx = 32768

# 1 リクエストで LLM に渡す書き起こしの最大文字数。
# 超えた分は先頭から切り詰められ WARN ログが出る。
# 目安: num_ctx × 0.9 程度（日本語 1 文字 ≈ 1.3 トークン換算）
# (default: 30000)
max_input_chars = 30000

# Ollama HTTP リクエストのタイムアウト秒。
# num_ctx >= 32768 で長尺処理する場合は 600 以上推奨 (default: 600.0)
request_timeout_seconds = 600.0

# 任意 Git リポジトリへの自動 PR 作成 (default: 全て off)
#
# 有効化すると、トランスクリプト（および議事録）書き出し完了直後に
# 指定したローカルクローンの Git リポジトリへ:
#   1) origin/<default_branch> を fetch & ローカルを clean state に reset
#   2) 新規ブランチ <branch_prefix><YYYY-MM-DD>-<6文字ランダム> を切る
#   3) transcript_subdir / minutes_subdir に md をコピーしてコミット
#   4) origin に push して `gh pr create` で PR を作成
# まで自動で行う。失敗してもトランスクリプト本体には影響しないが、
# PR 作成失敗時は元音声のゴミ箱送り (trash_source_after_success) もスキップされる。
#
# 警告:
# - この機能はトランスクリプト全文を push 先リポジトリにコミットします。
#   録音内容に機微情報を含む可能性がある場合、push 先は private リポジトリに
#   限定してください。
# - 認証は実行ユーザーの `gh` CLI 認証情報に依存します
#   （`gh auth status` で確認）。
# - 事前にローカルクローンを `git clone` 済みであること。
[auto_pr]
# false の場合、PR 作成連携を一切行わない (default: false)
enabled = false

# push 先のローカルクローンパス（事前に手動で `git clone` しておく）
repo_path = "~/path/to/your-repo"

# 配置先（リポジトリルートからの相対パス、空文字 "" ならリポジトリルート直下）
transcript_subdir = ""
minutes_subdir = ""

# PR のベースブランチ
default_branch = "main"

# ブランチ名: <branch_prefix><YYYY-MM-DD>-<6文字ランダム英数字>
branch_prefix = "auto-transcript/"

# テンプレート変数: {date}, {transcript_name}, {minutes_name}, {topic}, {branch}
# 未定義変数は空文字に置換される
commit_message_template = "add transcript for {date}"
pr_title_template       = "add transcript for {date}"
pr_body_template = """\
Auto-generated by mlx-audio-transcriptor.

- transcript: {transcript_name}
- minutes: {minutes_name}
"""

# gh CLI の `-R` に渡すリポジトリ識別子 "<owner>/<repo>"。
# 空文字 "" なら repo_path の origin remote から自動推定される
gh_repo = ""
